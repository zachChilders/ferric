// Ferric Test Program
// This demonstrates script-style execution without needing a main() function
// Edit this file and run: cargo run examples/test.fe

// Top-level script statements - executed in order
let x = 5
let y = 10
let result = x + y * 2

// This expression will be the final result
result

// You can also define functions that can be called from the script
fn add(x: Int, y: Int) -> Int {
    x + y
}

fn factorial(n: Int) -> Int {
    if n == 0 {
        1
    } else {
        n * factorial(n - 1)
    }
}

fn fibonacci(n: Int) -> Int {
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    }
}

fn complex_expression() -> Int {
    let a = 1 + 2 * 3;
    let b = 10 - 5 / 2;
    let c = a * b;

    if c > 20 {
        c
    } else {
        0
    }
}

fn test_booleans() -> Bool {
    let x = 5;
    let y = 10;

    if x < y && y > 0 {
        true
    } else {
        false
    }
}

fn nested_blocks() -> Int {
    let outer = 5;
    {
        let inner = 10;
        outer + inner
    }
}
